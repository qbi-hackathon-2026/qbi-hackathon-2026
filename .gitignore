# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ── Secrets / credentials (never commit) ─────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
# GCP service-account keys — should not exist (we use Workload Identity Federation),
# but ignore defensively so one can never be committed by accident.
gcp-*.json
service-account*.json
*-credentials.json

# ── TrimProt pipeline outputs / caches (regenerated per run) ─────────────
trimprot/outputs/
trimprot/cache/
trimprot/.venv/

# ── Editor / agent / OS local state ──────────────────────────────────────
.claude/
CLAUDE.md
trimprot/HOSTING.md
.vscode/
.idea/
.DS_Store

# ── Legacy Next.js scaffold cruft (pre-rewrite; not part of the project) ──
node_modules
.next
out
*.tsbuildinfo
next-env.d.ts

# Local integration planning doc (not published)
INTEGRATION.md
