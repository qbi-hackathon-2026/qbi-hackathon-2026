# BindScout local environment — copy this file to ".env" and fill in your key.
#
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# Your .env is gitignored, so your key is never committed. Each person uses their
# own key. After editing .env, (re)start the server: uv run python -m bindscout.server
#
# Get a key at https://console.anthropic.com/ — it looks like sk-ant-...
ANTHROPIC_API_KEY=
